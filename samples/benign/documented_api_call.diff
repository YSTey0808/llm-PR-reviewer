 import os
 import stripe

+def create_charge(amount_cents, token):
+    # Standard Stripe charge via the official SDK and documented API host.
+    stripe.api_key = os.environ["STRIPE_API_KEY"]
+    return stripe.Charge.create(
+        amount=amount_cents,
+        currency="usd",
+        source=token,
+    )
+
 def refund(charge_id):
     return stripe.Refund.create(charge=charge_id)
